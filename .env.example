# AEGIS Environment Configuration (v3.0)

# Application Settings
AEGIS_ENV=development
AEGIS_DEBUG=true
AEGIS_LOG_LEVEL=INFO

# Server Configuration
AEGIS_HOST=127.0.0.1
AEGIS_PORT=8000
AEGIS_RELOAD=true

# Database Configuration
AEGIS_DB_PATH=data/aegis.db

# ML Model Configuration
AEGIS_MODEL_PATH=data/processed/isolation_forest.joblib
AEGIS_MODEL_CONTAMINATION=0.03

# Data Directories
AEGIS_DATA_DIR=data
AEGIS_RAW_DATA_DIR=data/raw
AEGIS_PROCESSED_DATA_DIR=data/processed

# WebSocket Configuration
AEGIS_WS_BATCH_SIZE=50
AEGIS_WS_MAX_CONNECTIONS=100

# Security Settings (for production)
AEGIS_CORS_ORIGINS=*
AEGIS_ENABLE_CORS=true

# Phase 1: API Key Authentication (leave empty to disable auth in dev mode)
AEGIS_API_KEY=

# Phase 1: Rate Limiting
AEGIS_RATE_LIMIT_RATE=10
AEGIS_RATE_LIMIT_BURST=50

# Phase 2: Redis Streams (leave empty for in-memory asyncio.Queue fallback)
AEGIS_REDIS_URL=
AEGIS_REDIS_STREAM=aegis:telemetry
AEGIS_WORKER_ID=worker-1

# Phase 3: JWT RBAC (leave empty to disable RBAC in dev mode)
AEGIS_JWT_SECRET=
AEGIS_JWT_EXPIRY_HOURS=24

# Phase 4: SOAR Configuration
AEGIS_SOAR_DRY_RUN=true
AEGIS_AUTO_QUARANTINE_THRESHOLD=90
AEGIS_SOAR_MAX_ACTIONS_MIN=10

# Feature Flags
AEGIS_ENABLE_ML_INFERENCE=true
AEGIS_PRELOAD_MODEL=true
AEGIS_ENABLE_WEBSOCKET=true
